# ============================================================
# 1. DYNAMIC GLOBAL CACHE
# ============================================================
startup --output_base=/tmp/bazel-global-cache

# ============================================================
# 2. STARTUP: JVM & MEMORY (M1 Max Tuned)
# ============================================================
startup --max_idle_secs=10800
startup --host_jvm_args=-Xmx16g
startup --host_jvm_args=-XX:+UseG1GC
startup --host_jvm_args=-XX:MaxGCPauseMillis=20

# ============================================================
# 3. COMMON SETTINGS
# ============================================================
common --announce_rc
common --color=yes
common --watchfs
common --incompatible_strict_action_env
common --repository_cache=/tmp/bazel-repo-cache

# ============================================================
# 4. DEFAULT PERFORMANCE (Speed > Binary Quality)
# ============================================================
build --compilation_mode=fastbuild
build --copt=-O0
build --copt=-g0
build --strip=always
build --features=-dsym_selection

# Resource limits (Individual lines for syntax)
build --local_resources=cpu=8
build --local_resources=memory=24576
build --jobs=8

# I/O Speedups
build --nolegacy_external_runfiles
build --nobuild_runfile_links
build --reuse_sandbox_directories

# ============================================================
# 5. DOCKER CONFIG (--config=docker) - ULTRA PERFORMANCE
# ============================================================
# Matches your Rancher allocation (9 CPUs)
build:docker --jobs=9
build:docker --local_resources=cpu=9
build:docker --local_resources=memory=32768

# The "Secret Sauce" for Docker-on-Mac Speed:
# 1. Disable Sandboxing (Docker is already an isolated environment)
build:docker --spawn_strategy=local
build:docker --strategy=CppCompile=local
build:docker --strategy=Javac=worker
build:docker --genrule_strategy=local

# 2. Caching & Persistence
build:docker --disk_cache=/tmp/bazel-disk-cache
build:docker --worker_max_instances=4

# 3. Reduce I/O operations (fewer symlinks, fewer writes)
build:docker --nobuild_runfile_links
build:docker --linkopt=-S
build:docker --incompatible_strict_action_env

# ============================================================
# 6. MACOS NATIVE CONFIG (--config=macos)
# ============================================================
build:macos --jobs=10
build:macos --cpu=darwin_arm64
build:macos --macos_cpus=arm64
build:macos --apple_generate_dsym=false
build:macos --disk_cache=~/Library/Caches/bazel-disk-cache
build:macos --copt=-faligned-allocation
build:macos --copt=-mmacosx-version-min=11.0
build:macos --linkopt=-mmacosx-version-min=11.0