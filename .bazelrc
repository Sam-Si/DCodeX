# ============================================================
# DCodeX: Linux / Docker Native Built-In Config
# Optimized for maximum speed in isolated container environments
# ============================================================

# ------------------------------------------------------------
# 1. DYNAMIC GLOBAL CACHE
# ------------------------------------------------------------
startup --output_base=.bazel/output_base

# ------------------------------------------------------------
# 2. STARTUP: JVM & MEMORY (Linux Conservative)
# ------------------------------------------------------------
startup --max_idle_secs=10800
# NOTE: Host JVM args are best explicitly passed by the 
# dcodex-setup.sh script for runtime discovery, omitting hard limits here
startup --host_jvm_args=-XX:+UseG1GC
startup --host_jvm_args=-XX:MaxGCPauseMillis=20

# ------------------------------------------------------------
# 3. COMMON SETTINGS
# ------------------------------------------------------------
common --announce_rc
common --color=yes
common --incompatible_strict_action_env
common --repository_cache=.bazel/repo_cache
build --symlink_prefix=.bazel/

# ------------------------------------------------------------
# 4. DEFAULT PERFORMANCE (Speed > Build Size > Warnings)
# ------------------------------------------------------------
build --compilation_mode=fastbuild
build --copt=-O0
build --copt=-g0
build --copt=-w
build --strip=always

# ------------------------------------------------------------
# 5. LINUX & DOCKER "SECRET SAUCE": Disable Sandboxing
# Docker already provides an isolation boundary via namespaces.
# Disabling Bazel's internal sandbox saves enormous overhead.
# ------------------------------------------------------------
build --spawn_strategy=local
build --strategy=CppCompile=local
build --strategy=CppLink=local
build --genrule_strategy=local

# ------------------------------------------------------------
# 6. CACHING & FAST I/O
# ------------------------------------------------------------
build --disk_cache=.bazel/disk_cache
build --nobuild_runfile_links
build --nolegacy_external_runfiles

# ------------------------------------------------------------
# 7. LINUX COMPILER TOOLCHAIN (Clang & LLD)
# ------------------------------------------------------------
build:linux --repo_env=CC=clang
build:linux --repo_env=CXX=clang++
build:linux --linkopt=-fuse-ld=lld

# ------------------------------------------------------------
# 8. LINUX WORKERS & RESOURCES (16-Core / 64GB)
# ------------------------------------------------------------
build:linux --jobs=20
build:linux --local_resources=cpu=16
build:linux --local_resources=memory=57344
build:linux --worker_max_instances=16
build:linux --linkopt=-Wl,--threads=16
build:linux --gc_thrashing_threshold=95

# ------------------------------------------------------------
# 9. MACOS CONFIGURATION (M1 / M-Series)
# ------------------------------------------------------------
build:macos --jobs=10
build:macos --local_resources=cpu=8
build:macos --local_resources=memory=16384
build:macos --cpu=darwin_arm64
build:macos --macos_cpus=arm64
build:macos --apple_generate_dsym=false
build:macos --copt=-faligned-allocation
build:macos --copt=-mmacosx-version-min=12.0
build:macos --linkopt=-mmacosx-version-min=12.0
build:macos --features=-layering_check