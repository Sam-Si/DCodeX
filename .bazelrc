# ============================================================
# DCodeX: Linux / Docker Native Built-In Config
# Optimized for maximum speed in isolated container environments
# ============================================================

# ------------------------------------------------------------
# 1. DYNAMIC GLOBAL CACHE
# ------------------------------------------------------------
startup --output_base=/tmp/bazel-global-cache

# ------------------------------------------------------------
# 2. STARTUP: JVM & MEMORY (Linux Conservative)
# ------------------------------------------------------------
startup --max_idle_secs=10800
# NOTE: Host JVM args are best explicitly passed by the 
# dcodex-setup.sh script for runtime discovery, omitting hard limits here
startup --host_jvm_args=-XX:+UseG1GC
startup --host_jvm_args=-XX:MaxGCPauseMillis=20

# ------------------------------------------------------------
# 3. COMMON SETTINGS
# ------------------------------------------------------------
common --announce_rc
common --color=yes
common --incompatible_strict_action_env
common --repository_cache=/tmp/bazel-repo-cache
build --symlink_prefix=.bazel/

# ------------------------------------------------------------
# 4. DEFAULT PERFORMANCE (Speed > Build Size > Warnings)
# ------------------------------------------------------------
build --compilation_mode=fastbuild
build --copt=-O0
build --copt=-g0
build --copt=-w
build --strip=always

# ------------------------------------------------------------
# 5. LINUX & DOCKER "SECRET SAUCE": Disable Sandboxing
# Docker already provides an isolation boundary via namespaces.
# Disabling Bazel's internal sandbox saves enormous overhead.
# ------------------------------------------------------------
build --spawn_strategy=local
build --strategy=CppCompile=local
build --strategy=CppLink=local
build --genrule_strategy=local

# ------------------------------------------------------------
# 6. CACHING & FAST I/O
# ------------------------------------------------------------
build --disk_cache=/tmp/dcodex-bazel-cache
build --nobuild_runfile_links
build --nolegacy_external_runfiles

# ------------------------------------------------------------
# 7. LINUX COMPILER TOOLCHAIN (Clang & LLD)
# lld is significantly faster than GNU ld for large C++ targets.
# ------------------------------------------------------------
build --repo_env=CC=clang
build --repo_env=CXX=clang++
build --linkopt=-fuse-ld=lld

# ------------------------------------------------------------
# 8. WORKERS & RESOURCE SCALING (Tuned for 16-Core / 64GB Node)
# Container environments often misreport cgroups. Hard-coding 
# prevents over-saturation.
# ------------------------------------------------------------
build --jobs=20
build --local_resources=cpu=16
build --local_resources=memory=57344
build --worker_max_instances=16
build --linkopt=-Wl,--threads=16
build --gc_thrashing_threshold=95